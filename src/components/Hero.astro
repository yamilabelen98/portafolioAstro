---
import { Image } from 'astro:assets';
import Badge from '../components/Badge.astro';
import LinkedInIcon from '../components/icon/Linkedin.astro';
import MailIcon from '../components/icon/Mail.astro';
import Certificado from '../components/icon/Certificado.astro';
import SocialPill from '../components/SocialPill.astro';
import Arrow from '../components/icon/Arrow.astro';
import { profile } from '../data/profile';
---

<div class="max-w-xl">
  <div class="flex gap-4 mb-4">
    <span
      class="relative inline-flex items-center justify-center overflow-hidden rounded-full p-[2.5px]"
    >
      <span
        class="absolute inset-0 animate-spin bg-[conic-gradient(from_90deg_at_50%_50%,#ed6195_0%,#00ffff_50%,#ed6195_100%)]
dark:bg-[conic-gradient(from_90deg_at_50%_50%,#eb00bc_0%,#00d2ff_50%,#eb00bc_100%)]"
      ></span>
      <Image
        class="relative rounded-full shadow-lg w-16 h-16"
        src="/Img/photo.webp"
        alt={profile.imageAlt}
        width={64}
        height={64}
        loading="eager"
        format="webp"
      />
    </span>
    <a
      href={profile.cvPath}
      target="_blank"
      rel="noopener"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge>Disponible para trabajar, CV<Arrow class="size-4" /></Badge>
    </a>
  </div>
  <h1 class="text-4xl font-bold tracking-tight text-black sm:text-5xl dark:text-white">
    Hola! Soy Yamila 👋
  </h1>
  <span
    class="mt-3 font-bold inline-flex animate-background-shine
           bg-[linear-gradient(110deg,#ed6195,45%,#00ffff,55%,#ed6195)]
           dark:bg-[linear-gradient(110deg,#eb00bc,45%,#00d2ff,55%,#eb00bc)]
           bg-[length:250%_100%] bg-clip-text text-xl text-transparent"
  >
    {profile.role}
  </span>
  <p
    class="mt-6 text-xl text-black dark:[&>strong]:text-[#eb00bc] [&>strong]:text-[#ed6195] [&>strong]:font-semibold dark:text-gray-100"
  >
    {profile.summary} <strong>{profile.summaryHighlight}</strong>, {profile.location}. {profile.summaryClosing}
  </p>
  <nav class="flex flex-wrap gap-4 mt-8">
    <SocialPill href={profile.links.email}>
      <MailIcon class="size-5" />
      Contáctame
    </SocialPill>
    <SocialPill href={profile.links.linkedin}>
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
    <SocialPill href={profile.links.henryCertificate}>
      <Certificado class="size-5" />
      Certificado Henry
    </SocialPill>
    <SocialPill href={profile.links.qaCertificate}>
      <Certificado class="size-5" />
      Certificado QA Testing
    </SocialPill>
  </nav>
</div>
